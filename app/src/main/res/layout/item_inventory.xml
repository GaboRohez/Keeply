<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clipChildren="false">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/swipeActionsContainer"
        android:layout_margin="2dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/keeply_surface_tint"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/consumeAction"
                android:layout_width="88dp"
                android:layout_height="match_parent"
                android:layout_gravity="start"
                android:background="@color/keeply_warning_container"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/tvConsumeBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/onest"
                    android:text="@string/inventory_consume_badge"
                    android:textColor="@color/keeply_on_warning_container"
                    android:textFontWeight="700"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvConsumeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/onest"
                    android:gravity="center"
                    android:text="@string/inventory_consume_label"
                    android:textColor="@color/keeply_on_warning_container"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnEdit"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_swipe_action"
                    android:contentDescription="@string/product_edit"
                    android:elevation="2dp"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_edit" />

                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_swipe_action"
                    android:contentDescription="@string/product_delete"
                    android:elevation="2dp"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_delete" />
            </LinearLayout>
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardForeground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.Keeply.WhiteCard"
        app:cardBackgroundColor="@android:color/white"
        android:layout_margin="2dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <ImageView
                android:id="@+id/ivThumb"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_item_thumb"
                android:contentDescription="@null"
                android:padding="10dp"
                android:scaleType="centerCrop"
                android:src="@drawable/placeholder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/titleRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toStartOf="@id/tvMeta"
                app:layout_constraintStart_toEndOf="@id/ivThumb"
                app:layout_constraintTop_toTopOf="@id/ivThumb">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:fontFamily="@font/onest"
                    android:maxLines="1"
                    android:textColor="@color/keeply_text_primary"
                    android:textFontWeight="700"
                    android:textSize="15sp"
                    tools:text="Paracetamol" />

                <TextView
                    android:id="@+id/tvCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:ellipsize="end"
                    android:fontFamily="@font/onest"
                    android:maxLines="1"
                    android:textColor="@color/keeply_text_secondary"
                    android:textSize="12sp"
                    tools:text="(Medicinas)" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/onest"
                android:textColor="@color/keeply_text_secondary"
                android:textSize="13sp"
                app:layout_constraintEnd_toStartOf="@id/tvMeta"
                app:layout_constraintStart_toStartOf="@id/titleRow"
                app:layout_constraintTop_toBottomOf="@id/titleRow"
                tools:text="24 en stock" />

            <ImageView
                android:id="@+id/ivBarcode"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_barcode"
                app:layout_constraintBottom_toBottomOf="@id/ivThumb"
                app:layout_constraintStart_toStartOf="@id/titleRow" />

            <TextView
                android:id="@+id/tvBarcode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="8dp"
                android:ellipsize="end"
                android:fontFamily="@font/onest"
                android:maxLines="1"
                android:textColor="@color/keeply_text_secondary"
                android:textSize="11sp"
                app:layout_constraintBottom_toBottomOf="@id/ivBarcode"
                app:layout_constraintStart_toEndOf="@id/ivBarcode"
                app:layout_constraintTop_toTopOf="@id/ivBarcode"
                tools:text="7501234567890" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
