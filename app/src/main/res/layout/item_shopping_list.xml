<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clipChildren="false">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/swipeActionsContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:theme="@style/ThemeOverlay.Keeply.WhiteCard"
        android:layout_margin="2dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_swipe_action"
                android:contentDescription="@string/product_edit"
                android:elevation="2dp"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_edit" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_swipe_action"
                android:contentDescription="@string/product_delete"
                android:elevation="2dp"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_delete" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardForeground"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/keeply_surface"
        app:cardCornerRadius="20dp"
        android:theme="@style/ThemeOverlay.Keeply.WhiteCard"
        android:layout_margin="2dp"
        app:rippleColor="@color/keeply_primary_container"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvListName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/onest"
                    android:textColor="@color/keeply_text_primary"
                    android:textFontWeight="700"
                    android:textSize="16sp"
                    tools:text="Despensa semanal" />

                <TextView
                    android:id="@+id/tvListMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="@font/onest"
                    android:textColor="@color/keeply_text_secondary"
                    android:textSize="13sp"
                    tools:text="4 pendientes · Auto" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/onest"
                android:text="@string/settings_chevron"
                android:textColor="@color/keeply_text_tertiary"
                android:textSize="22sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
