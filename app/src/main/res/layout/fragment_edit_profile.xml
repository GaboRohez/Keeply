<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/keeply_background"
    tools:context=".presentation.settings.EditProfileFragment">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@null"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/keeply_text_primary" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/onest"
        android:text="@string/settings_profile_title"
        android:textColor="@color/keeply_text_primary"
        android:textFontWeight="700"
        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollForm"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btnSave"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                app:cardBackgroundColor="@color/keeply_surface"
                app:cardElevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Keeply.Search"
                app:strokeWidth="0dp">

                <EditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="@font/onest"
                    android:hint="@string/profile_field_name"
                    android:inputType="textPersonName|textCapWords"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/keeply_text_primary"
                    android:textColorHint="@color/keeply_text_tertiary"
                    android:textSize="15sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/keeply_surface"
                app:cardElevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Keeply.Search"
                app:strokeWidth="0dp">

                <EditText
                    android:id="@+id/etAge"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="@font/onest"
                    android:hint="@string/profile_field_age"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/keeply_text_primary"
                    android:textColorHint="@color/keeply_text_tertiary"
                    android:textSize="15sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/keeply_surface"
                app:cardElevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Keeply.Search"
                app:strokeWidth="0dp">

                <EditText
                    android:id="@+id/etBloodType"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="@font/onest"
                    android:hint="@string/profile_field_blood_type"
                    android:inputType="textCapCharacters"
                    android:maxLength="5"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/keeply_text_primary"
                    android:textColorHint="@color/keeply_text_tertiary"
                    android:textSize="15sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/keeply_surface"
                app:cardElevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Keeply.Search"
                app:strokeWidth="0dp">

                <EditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="@font/onest"
                    android:hint="@string/profile_field_phone"
                    android:inputType="phone"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/keeply_text_primary"
                    android:textColorHint="@color/keeply_text_tertiary"
                    android:textSize="15sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/keeply_surface"
                app:cardElevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Keeply.Search"
                app:strokeWidth="0dp">

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:fontFamily="@font/onest"
                    android:hint="@string/profile_field_email"
                    android:inputType="textEmailAddress"
                    android:maxLines="1"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/keeply_text_primary"
                    android:textColorHint="@color/keeply_text_tertiary"
                    android:textSize="15sp" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/keeply_surface"
                app:cardElevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Keeply.Search"
                app:strokeWidth="0dp">

                <EditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="@font/onest"
                    android:gravity="top"
                    android:hint="@string/profile_field_notes"
                    android:inputType="textMultiLine"
                    android:minHeight="96dp"
                    android:minLines="3"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:textColor="@color/keeply_text_primary"
                    android:textColorHint="@color/keeply_text_tertiary"
                    android:textSize="15sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/onest"
        android:text="@string/product_save"
        android:textAllCaps="false"
        app:backgroundTint="@color/keeply_primary"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
