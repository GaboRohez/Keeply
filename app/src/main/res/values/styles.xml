<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="ShapeAppearance.Keeply.Card" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <style name="ShapeAppearance.Keeply.Search" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>

    <style name="ShapeAppearance.Keeply.SmallCard" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.Keeply.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_filter_background</item>
        <item name="android:textColor">@color/chip_filter_text</item>
        <item name="checkedIconVisible">true</item>
        <item name="checkedIconTint">@color/chip_filter_icon</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="ensureMinTouchTargetSize">true</item>
    </style>

    <!-- Evita el tinte azul de elevación de Material 3 en cards blancas -->
    <style name="ThemeOverlay.Keeply.WhiteCard" parent="">
        <item name="colorSurface">@android:color/white</item>
        <item name="elevationOverlayEnabled">false</item>
    </style>
</resources>
