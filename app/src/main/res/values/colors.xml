    <!-- Borders / Dividers        -->
    <!-- ========================= -->
    <color name="keeply_outline">#FFE5E7EF</color>
    <color name="keeply_outline_variant">#FFF0F1F5</color>
    <color name="keeply_divider">#FFECEEF3</color>

    <!-- ========================= -->
    <!-- Semantic                  -->
    <!-- ========================= -->
    <color name="keeply_error">#FFE57373</color>
    <color name="keeply_on_error">#FFFFFFFF</color>
    <color name="keeply_error_container">#FFFFEBEE</color>
    <color name="keeply_on_error_container">#FF8E2424</color>

    <color name="keeply_success">#FF4CAF82</color>
