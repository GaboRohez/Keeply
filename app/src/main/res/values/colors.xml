<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ========================= -->
    <!-- Brand / Primary           -->
    <!-- ========================= -->
    <color name="keeply_primary">#FF4F6CF1</color>
    <color name="keeply_primary_dark">#FF3B56D6</color>
    <color name="keeply_primary_light">#FF7B90F6</color>
    <color name="keeply_on_primary">#FFFFFFFF</color>
    <color name="keeply_primary_container">#FFE8ECFF</color>
    <color name="keeply_on_primary_container">#FF1B2A7A</color>

    <!-- ========================= -->
    <!-- Backgrounds / Surfaces    -->
    <!-- ========================= -->
    <color name="keeply_background">#f1f3f4</color>
    <color name="keeply_on_background">#6f7271</color>

    <color name="keeply_surface">#FFFFFFFF</color>
    <color name="keeply_on_surface">#FF121212</color>
    <color name="keeply_surface_variant">#FFF1F3FE</color>
    <color name="keeply_on_surface_variant">#FF5C5C63</color>

    <!-- Swipe actions / soft accent panels -->
    <color name="keeply_surface_tint">#FFEEF0FF</color>

    <!-- Bottom navigation / elevated bars -->
    <color name="keeply_nav_background">#FFFFFFFF</color>
    <color name="nav_item_selected">#292b2c</color>
    <color name="nav_item_unselected">#909090</color>

    <!-- ========================= -->
    <!-- Text                       -->
    <!-- ========================= -->
    <color name="keeply_text_primary">#FF121212</color>
    <color name="keeply_text_secondary">#FF949596</color>
    <color name="keeply_text_tertiary">#FFB0B1B5</color>
    <color name="keeply_text_disabled">#FFC7C8CC</color>
    <color name="keeply_text_on_primary">#FFFFFFFF</color>
    <color name="keeply_text_link">#FF4F6CF1</color>

    <!-- ========================= -->
    <!-- Icons                     -->
    <!-- ========================= -->
    <color name="keeply_icon_primary">#FF1A1A1A</color>
    <color name="keeply_icon_secondary">#FF8E8E93</color>
    <color name="keeply_icon_active">#FF4F6CF1</color>
    <color name="keeply_icon_on_primary">#FFFFFFFF</color>

