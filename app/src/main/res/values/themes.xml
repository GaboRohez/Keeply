<resources>
    <!-- Base application theme. -->
    <style name="Base.Theme.Keeply" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Colors (inventory mockup) -->
        <item name="colorPrimary">@color/keeply_primary</item>
        <item name="colorOnPrimary">@color/keeply_on_primary</item>
        <item name="colorPrimaryContainer">@color/keeply_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/keeply_on_primary_container</item>

        <item name="colorSecondary">@color/keeply_primary_light</item>
        <item name="colorOnSecondary">@color/keeply_on_primary</item>
        <item name="colorSecondaryContainer">@color/keeply_surface_variant</item>
        <item name="colorOnSecondaryContainer">@color/keeply_on_primary_container</item>

        <item name="android:colorBackground">@color/keeply_background</item>
        <item name="colorOnBackground">@color/keeply_on_background</item>
        <item name="colorSurface">@color/keeply_surface</item>
        <item name="colorOnSurface">@color/keeply_on_surface</item>
        <item name="colorSurfaceVariant">@color/keeply_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/keeply_on_surface_variant</item>

        <item name="colorOutline">@color/keeply_outline</item>
        <item name="colorOutlineVariant">@color/keeply_outline_variant</item>

        <item name="colorError">@color/keeply_error</item>
        <item name="colorOnError">@color/keeply_on_error</item>
        <item name="colorErrorContainer">@color/keeply_error_container</item>
        <item name="colorOnErrorContainer">@color/keeply_on_error_container</item>

        <item name="android:statusBarColor">@color/keeply_background</item>
        <item name="android:navigationBarColor">@color/keeply_nav_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Typography -->
        <item name="fontFamily">@font/onest</item>
        <item name="android:fontFamily">@font/onest</item>

        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Keeply.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.Keeply.DisplayMedium</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Keeply.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Keeply.HeadlineMedium</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Keeply.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Keeply.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Keeply.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Keeply.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Keeply.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Keeply.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Keeply.LabelMedium</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Keeply.MaterialAlertDialog</item>
    </style>

    <style name="Theme.Keeply" parent="Base.Theme.Keeply" />

    <style name="Theme.Keeply.Splash" parent="Theme.Keeply">
        <item name="android:windowBackground">@drawable/bg_splash</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>